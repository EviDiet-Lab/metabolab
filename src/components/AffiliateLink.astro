---
export interface Props {
  href: string;
  label: string;
  type?: 'amazon' | 'rakuten' | 'generic';
  badge?: string;
}

const { href, label, type = 'generic', badge } = Astro.props;
const badgeLabel = badge || ({ amazon: 'Amazon', rakuten: '楽天市場', generic: 'PR' }[type] || 'PR');
---

<a href={href} class="affiliate-link" target="_blank" rel="nofollow sponsored noopener noreferrer">
  <span class="affiliate-badge">{badgeLabel}</span>
  <span class="affiliate-label">{label}</span>
  <span class="affiliate-arrow">→</span>
</a>

<style is:global>
  .affiliate-link { display: inline-flex; align-items: center; gap: var(--space-sm); padding: var(--space-sm) var(--space-md); border: 1px solid var(--color-secondary); border-radius: var(--border-radius); color: var(--color-text); text-decoration: none; transition: all 0.2s; margin: var(--space-xs) 0; font-size: var(--font-size-sm); }
  .affiliate-link:hover { background: rgba(230,126,34,0.05); transform: translateX(2px); opacity: 1; }
  .affiliate-badge { font-size: 0.6rem; font-weight: 700; padding: 0.15rem 0.4rem; border-radius: 2px; background: var(--color-secondary); color: #fff; white-space: nowrap; }
  .affiliate-label { flex: 1; }
  .affiliate-arrow { font-size: 0.8rem; opacity: 0.6; }
</style>
