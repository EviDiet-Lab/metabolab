---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const articles = await getCollection('articles');
  return articles.map(entry => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();

const categoryNames: Record<string, string> = {
  diet: 'ダイエット',
  exercise: '運動',
  sleep: '睡眠',
  recipe: 'レシピ',
  mental: 'メンタル',
};
const catLabel = categoryNames[entry.data.category] || entry.data.category;
---

<BaseLayout title={entry.data.title} description={entry.data.description} image={entry.data.image} type="article" publishedTime={entry.data.pubDate.toISOString()}>
  <article class="container section article-detail">
    <nav class="breadcrumb">
      <a href="/metabolab/">ホーム</a>
      &gt; <a href={`/metabolab/categories/${entry.data.category}`}>{catLabel}</a>
      &gt; <span>{entry.data.title}</span>
    </nav>

    <header class="article-header">
      <span class="tag">{catLabel}</span>
      <h1>{entry.data.title}</h1>
      <div class="article-header-meta">
        <time datetime={entry.data.pubDate.toISOString()}>
          公開日: {entry.data.pubDate.toLocaleDateString("ja-JP", { year: "numeric", month: "long", day: "numeric" })}
        </time>
        {entry.data.tags && entry.data.tags.length > 0 && (
          <div class="article-tags">
            {entry.data.tags.map(tag => <span class="tag-sm">{tag}</span>)}
          </div>
        )}
      </div>
      {entry.data.image && (
        <img src={entry.data.image} alt={entry.data.title} class="article-hero-image" loading="eager" />
      )}
    </header>

    <div class="article-body">
      <Content />
    </div>

    <nav class="article-footer-nav">
      <a href={`/metabolab/categories/${entry.data.category}`} class="btn btn-outline">← {catLabel}の記事一覧に戻る</a>
    </nav>
  </article>
</BaseLayout>

<style is:global>
  .breadcrumb { font-size: var(--font-size-sm); color: var(--color-text-light); margin-bottom: var(--space-lg); }
  .breadcrumb a { color: var(--color-text-light); }
  .article-header { margin-bottom: var(--space-xl); }
  .article-header h1 { margin-top: var(--space-sm); }
  .article-header-meta { display: flex; align-items: center; gap: var(--space-md); font-size: var(--font-size-sm); color: var(--color-text-light); margin-bottom: var(--space-md); }
  .tag-sm { display: inline-block; padding: 0.1rem 0.4rem; font-size: 0.65rem; border-radius: 2px; background: var(--color-border); color: var(--color-text-light); margin-right: 0.25rem; }
  .article-hero-image { width: 100%; max-height: 400px; object-fit: cover; border-radius: var(--border-radius-lg); margin-top: var(--space-md); }
  .article-body { line-height: 1.9; font-size: var(--font-size-base); }
  .article-body h2 { margin-top: var(--space-2xl); }
  .article-body h3 { margin-top: var(--space-xl); }
  .article-body blockquote { border-left: 4px solid var(--color-secondary); padding: var(--space-sm) var(--space-md); margin: var(--space-md) 0; background: rgba(230,126,34,0.05); }
  .article-footer-nav { margin-top: var(--space-3xl); padding-top: var(--space-xl); border-top: 1px solid var(--color-border); }
</style>
