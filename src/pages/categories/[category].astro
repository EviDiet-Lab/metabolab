---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const categories = ['diet', 'exercise', 'sleep', 'recipe', 'mental'];
  return categories.map(cat => ({
    params: { category: cat },
  }));
}

const { category } = Astro.params;
const allArticles = await getCollection('articles');
const filtered = allArticles
  .filter(entry => entry.data.category === category)
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());

const categoryNames: Record<string, string> = {
  diet: 'ダイエット',
  exercise: '運動',
  sleep: '睡眠',
  recipe: 'レシピ',
  mental: 'メンタル',
};
const catLabel = categoryNames[category || ''] || category;
---

<BaseLayout title={`${catLabel}の記事一覧`} description={`MetaboLabの${catLabel}に関するエビデンスベースの記事一覧です。`}>
  <div class="container section">
    <nav class="breadcrumb">
      <a href="/metabolab/">ホーム</a> &gt; <span>{catLabel}</span>
    </nav>
    <h1>{catLabel}の記事一覧</h1>

    {filtered.length === 0 && (
      <div class="card empty-state">
        <p>現在、このカテゴリの記事は準備中です。しばらくお待ちください。</p>
      </div>
    )}

    <div class="article-grid">
      {filtered.map(entry => (
        <ArticleCard
          title={entry.data.title}
          description={entry.data.description}
          pubDate={entry.data.pubDate}
          category={entry.data.category}
          slug={entry.slug}
          image={entry.data.image}
          tags={entry.data.tags}
        />
      ))}
    </div>
  </div>
</BaseLayout>

<style is:global>
  .breadcrumb { font-size: var(--font-size-sm); color: var(--color-text-light); margin-bottom: var(--space-lg); }
  .breadcrumb a { color: var(--color-text-light); }
  .article-grid { display: flex; flex-direction: column; gap: var(--space-lg); }
  .empty-state { text-align: center; padding: var(--space-3xl); color: var(--color-text-light); }
</style>
